<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --blau:#0193de;--blau-dk:#0176b3;--blau-hell:#cceaf9;--blau-soft:#eaf6fd;
  --weiss:#fff;--creme:#fdf9f4;--warm:#f0a830;--dunkel:#1a2e3d;--grau:#5d7080;
  --font-h:'Nunito',sans-serif;--font-b:'Lora',serif;
}
html{scroll-behavior:smooth;}
body{font-family:var(--font-h);color:var(--dunkel);background:var(--weiss);}

nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,.96);backdrop-filter:blur(8px);border-bottom:1px solid #e0eef6;padding:0 5%;height:60px;display:flex;align-items:center;justify-content:space-between;}
.nav-logo{display:flex;align-items:center;gap:10px;}
.nav-badge{width:36px;height:36px;background:var(--blau);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:white;}
.nav-name{font-size:13px;font-weight:800;color:var(--blau);line-height:1.2;}
.nav-cta{background:var(--blau);color:white;font-family:var(--font-h);font-size:13px;font-weight:800;padding:8px 18px;border-radius:100px;border:none;cursor:pointer;text-decoration:none;}

.hero{margin-top:60px;position:relative;height:90vh;min-height:520px;overflow:hidden;display:flex;align-items:flex-end;}
.hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 30%;}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(26,46,61,.82) 0%,rgba(26,46,61,.3) 55%,rgba(26,46,61,.05) 100%);}
.hero-content{position:relative;z-index:2;padding:5% 6% 6%;width:100%;max-width:740px;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--warm);color:var(--dunkel);font-size:13px;font-weight:800;padding:6px 14px;border-radius:100px;margin-bottom:18px;}
.hero-title{font-size:clamp(30px,5vw,56px);font-weight:900;color:white;line-height:1.1;margin-bottom:14px;}
.hero-title em{color:var(--warm);font-style:normal;}
.hero-sub{font-family:var(--font-b);font-size:clamp(14px,1.8vw,18px);color:rgba(255,255,255,.85);line-height:1.65;margin-bottom:28px;max-width:500px;}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn-p{background:var(--blau);color:white;font-family:var(--font-h);font-size:15px;font-weight:800;padding:13px 26px;border-radius:100px;border:none;cursor:pointer;text-decoration:none;display:inline-block;}
.btn-g{background:rgba(255,255,255,.15);color:white;font-family:var(--font-h);font-size:15px;font-weight:700;padding:13px 26px;border-radius:100px;border:1.5px solid rgba(255,255,255,.4);text-decoration:none;display:inline-block;}
.hero-facts{position:absolute;right:5%;bottom:5%;z-index:2;display:flex;gap:10px;}
.hf{background:rgba(255,255,255,.12);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.2);border-radius:14px;padding:12px 16px;text-align:center;}
.hf-n{font-size:22px;font-weight:900;color:white;line-height:1;}
.hf-l{font-size:10px;color:rgba(255,255,255,.65);font-weight:700;letter-spacing:.06em;margin-top:3px;}
@media(max-width:640px){.hero-facts{display:none;}}

.banner{background:var(--blau);padding:18px 6%;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;}
.ban-l{display:flex;align-items:center;gap:14px;}
.ban-icon{font-size:26px;}
.ban-txt .ban-lbl{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.6);}
.ban-txt .ban-date{font-size:18px;font-weight:900;color:white;}
.ban-txt .ban-sub{font-family:var(--font-b);font-size:13px;color:rgba(255,255,255,.75);}
.ban-btn{background:var(--warm);color:var(--dunkel);font-family:var(--font-h);font-size:14px;font-weight:800;padding:10px 22px;border-radius:100px;border:none;cursor:pointer;text-decoration:none;white-space:nowrap;}

section{padding:72px 6%;}
.eyebrow{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:var(--blau);margin-bottom:8px;}
.sec-title{font-size:clamp(24px,3.2vw,38px);font-weight:900;color:var(--dunkel);line-height:1.15;margin-bottom:14px;}
.sec-sub{font-family:var(--font-b);font-size:16px;color:var(--grau);line-height:1.7;max-width:580px;}

.usp-bg{background:var(--creme);}
.usp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:18px;margin-top:44px;}
.usp-card{background:white;border-radius:18px;padding:26px 22px;border:1px solid #e0eef6;}
.usp-icon{font-size:30px;margin-bottom:12px;}
.usp-t{font-size:15px;font-weight:800;color:var(--dunkel);margin-bottom:7px;}
.usp-tx{font-family:var(--font-b);font-size:13px;color:var(--grau);line-height:1.6;}

.gruppen-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:44px;}
@media(max-width:700px){.gruppen-grid{grid-template-columns:1fr;}}
.gcard{border-radius:22px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.08);}
.gcard img{width:100%;height:200px;object-fit:cover;display:block;}
.gbody{padding:22px;}
.gicon{font-size:22px;margin-bottom:7px;}
.gname{font-size:18px;font-weight:900;color:var(--dunkel);margin-bottom:5px;}
.gtag{display:inline-block;font-size:11px;font-weight:800;padding:3px 9px;border-radius:100px;margin-bottom:9px;}
.g-spatz .gtag{background:#eaf6fd;color:var(--blau);}
.g-loewe .gtag{background:#fff4e0;color:#a06000;}
.g-maus .gtag{background:#edfaed;color:#1a6e1a;}
.gtx{font-family:var(--font-b);font-size:13px;color:var(--grau);line-height:1.55;}

.photo-strip{display:grid;grid-template-columns:2fr 1fr 1fr;gap:12px;}
@media(max-width:640px){.photo-strip{grid-template-columns:1fr 1fr;} .photo-strip img:first-child{grid-column:1/-1;height:220px;}}
.photo-strip img{width:100%;height:230px;object-fit:cover;border-radius:18px;display:block;}
.photo-strip img:first-child{height:250px;}

.dark-sec{background:var(--dunkel);}
.dark-sec .sec-title{color:white;}
.dark-sec .sec-sub{color:rgba(255,255,255,.65);}
.fakten-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-top:44px;}
.fakt{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:22px 18px;}
.fakt-n{font-size:32px;font-weight:900;color:var(--warm);line-height:1;margin-bottom:7px;}
.fakt-l{font-size:13px;font-weight:700;color:white;margin-bottom:3px;}
.fakt-s{font-family:var(--font-b);font-size:12px;color:rgba(255,255,255,.5);line-height:1.5;}

.form-bg{background:var(--blau-soft);}
.form-wrap{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;margin-top:44px;}
@media(max-width:740px){.form-wrap{grid-template-columns:1fr;}}
.fi h3{font-size:20px;font-weight:800;color:var(--dunkel);margin-bottom:14px;}
.fi p{font-family:var(--font-b);font-size:14px;color:var(--grau);line-height:1.7;margin-bottom:14px;}
.cblock{background:var(--blau);border-radius:16px;padding:22px;margin-top:20px;}
.cblock h4{font-size:13px;font-weight:800;color:white;margin-bottom:12px;}
.crow{display:flex;align-items:center;gap:9px;margin-bottom:8px;font-size:13px;color:rgba(255,255,255,.8);font-family:var(--font-b);}
.crow:last-child{margin-bottom:0;}
.fcard{background:white;border-radius:22px;padding:32px;box-shadow:0 8px 36px rgba(1,147,222,.12);}
.fcard h3{font-size:19px;font-weight:900;color:var(--dunkel);margin-bottom:5px;}
.fcard>p{font-family:var(--font-b);font-size:13px;color:var(--grau);margin-bottom:22px;}
.fg{margin-bottom:14px;}
.fg label{display:block;font-size:12px;font-weight:800;color:var(--dunkel);margin-bottom:5px;}
.fg input,.fg select,.fg textarea{width:100%;padding:11px 13px;border:1.5px solid #d0e8f5;border-radius:9px;font-family:var(--font-h);font-size:13px;color:var(--dunkel);background:white;outline:none;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--blau);}
.fg textarea{resize:vertical;min-height:75px;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.fsub{width:100%;background:var(--blau);color:white;font-family:var(--font-h);font-size:14px;font-weight:800;padding:13px;border-radius:100px;border:none;cursor:pointer;margin-top:6px;}
.fsub:hover{background:var(--blau-dk);}
.fnote{font-size:11px;color:var(--grau);font-family:var(--font-b);text-align:center;margin-top:10px;line-height:1.5;}

.std-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:44px;}
@media(max-width:640px){.std-grid{grid-template-columns:1fr;}}
.scard{background:white;border-radius:18px;padding:26px;border:1.5px solid #d8eef8;}
.sname{font-size:15px;font-weight:800;color:var(--blau);margin-bottom:3px;}
.sadr{font-family:var(--font-b);font-size:13px;color:var(--grau);margin-bottom:12px;}
.srow{display:flex;align-items:flex-start;gap:8px;margin-bottom:7px;font-size:13px;}
.srow span{font-family:var(--font-b);color:var(--grau);}

footer{background:var(--dunkel);color:white;padding:44px 6% 28px;}
.fg-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:36px;margin-bottom:28px;}
@media(max-width:640px){.fg-grid{grid-template-columns:1fr;gap:20px;}}
.fbrand{font-size:15px;font-weight:800;color:white;margin-bottom:8px;}
.fsub2{font-family:var(--font-b);font-size:13px;color:rgba(255,255,255,.45);line-height:1.6;}
.fcol h4{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.35);margin-bottom:10px;}
.fcol p,.fcol a{font-family:var(--font-b);font-size:13px;color:rgba(255,255,255,.65);text-decoration:none;display:block;margin-bottom:5px;line-height:1.5;}
.fbot{border-top:1px solid rgba(255,255,255,.1);padding-top:18px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.fbot p{font-size:12px;color:rgba(255,255,255,.3);font-family:var(--font-b);}

.reveal{opacity:0;transform:translateY(20px);transition:opacity .55s ease,transform .55s ease;}
.reveal.vis{opacity:1;transform:none;}
</style>
</head>
